---
import { t } from '../data/i18n.js';
const { locale } = Astro.props;
const s = t[locale];
const pageTitle = Astro.props.title ?? s.title;
const pageDesc = Astro.props.description ?? s.description;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const otherLocale = locale === 'en' ? 'ja' : 'en';
const otherHref = locale === 'en' ? '/ja/' : '/';
---
<!doctype html>
<html lang={s.htmlLang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en" href={new URL('/', Astro.site).href} />
  <link rel="alternate" hreflang="ja" href={new URL('/ja/', Astro.site).href} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content="https://promptpot.tatu-sec.dev/og-image.jpg" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
  <!-- set theme before paint to avoid flash -->
  <script is:inline>
    (function () {
      try {
        const saved = localStorage.getItem('theme');
        const sys = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.dataset.theme = saved || sys;
      } catch (e) {
        document.documentElement.dataset.theme = 'dark';
      }
    })();
  </script>
</head>
<body>
  <div class="wrap topbar">
    <a class="brand" href={locale === 'en' ? '/' : '/ja/'}>
      <img src="/icon.svg" alt="" width="60" height="60" />
      PromptPot
    </a>
    <div class="controls">
      <a class="ctl lang" href={otherHref} aria-label="Switch language">{otherLocale === 'ja' ? '日本語' : 'EN'}</a>
      <button class="ctl theme" id="theme-toggle" type="button" aria-label="Toggle color theme">
        <span class="theme-dark">☾</span><span class="theme-light">☀</span>
      </button>
    </div>
  </div>

  <slot />

  <script is:inline>
    const btn = document.getElementById('theme-toggle');
    btn && btn.addEventListener('click', () => {
      const cur = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = cur;
      try { localStorage.setItem('theme', cur); } catch (e) {}
    });
  </script>

  <!-- Cloudflare Web Analytics -->
  <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "9385fd5fe6d940a0ae9a0e8c1503323c"}'></script>
</body>
</html>

<style is:global>
  :root {
    --phosphor: #2ea043;
    --phosphor-bright: #3fb950;
    --amber: #bf8700;
    --mono: ui-monospace, "SF Mono", "SFMono-Regular", Menlo, Consolas, monospace;
    --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    --maxw: 940px;
  }
  /* dark theme tokens */
  :root[data-theme="dark"] {
    --ground: #0d1117; --ground-2: #0b0f14;
    --panel: #161b22; --panel-edge: #2a313c;
    --ink: #e6edf3; --muted: #8b98a5; --dim: #5c6773;
    --accent: #3fb950; --accent-dim: #2ea043; --warn: #d29922;
    --code-bg: #10151c;
    --glow: rgba(63,185,80,0.08);
  }
  /* light theme tokens */
  :root[data-theme="light"] {
    --ground: #fbfdfc; --ground-2: #f1f5f3;
    --panel: #ffffff; --panel-edge: #dfe6e1;
    --ink: #111a15; --muted: #4b5850; --dim: #8a968e;
    --accent: #1a7f37; --accent-dim: #1a7f37; --warn: #9a6700;
    --code-bg: #f2f5f3;
    --glow: rgba(26,127,55,0.07);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background:
      radial-gradient(900px 480px at 85% -8%, var(--glow), transparent 62%),
      linear-gradient(165deg, var(--ground) 0%, var(--ground-2) 100%);
    background-attachment: fixed;
    min-height: 100vh;
    color: var(--ink);
    font-family: var(--sans);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    transition: background-color .2s, color .2s;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }

  .topbar { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px 0; }
  .brand { font-family: var(--mono); font-weight: 700; font-size: 19px; color: var(--ink); display: inline-flex; align-items: center; gap: 10px; }
  .brand:hover { text-decoration: none; color: var(--accent); }
  .brand img { display: block; }
  .controls { display: flex; gap: 8px; align-items: center; }
  .ctl {
    font-family: var(--mono); font-size: 13px; color: var(--muted);
    background: var(--panel); border: 1px solid var(--panel-edge);
    border-radius: 8px; padding: 6px 12px; cursor: pointer; line-height: 1.4;
    display: inline-flex; align-items: center;
  }
  .ctl:hover { text-decoration: none; border-color: var(--accent-dim); color: var(--ink); }
  .theme-dark, .theme-light { font-size: 15px; }
  :root[data-theme="dark"] .theme-light { display: none; }
  :root[data-theme="light"] .theme-dark { display: none; }

  header { padding: 40px 0 52px; }
  .eyebrow { font-family: var(--mono); font-size: 14px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent); display: inline-flex; align-items: center; gap: 10px; margin-bottom: 22px; }
  .eyebrow .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 9px 2px var(--glow); }
  h1 { font-size: clamp(32px, 6vw, 56px); line-height: 1.05; font-weight: 800; letter-spacing: -0.02em; text-wrap: balance; margin-bottom: 20px; }
  h1 .hl { color: var(--accent); }
  .lede { font-size: clamp(17px, 2.4vw, 21px); color: var(--muted); max-width: 62ch; margin-bottom: 34px; }
  .cta-row { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .btn { font-family: var(--mono); font-size: 15px; font-weight: 600; padding: 12px 20px; border-radius: 9px; border: 1px solid var(--panel-edge); color: var(--ink); background: var(--panel); transition: border-color .15s, transform .15s; display: inline-flex; align-items: center; gap: 9px; }
  .btn:hover { text-decoration: none; border-color: var(--accent-dim); transform: translateY(-1px); }
  .btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn.primary:hover { background: var(--phosphor-bright); }
  .btn .metric { font-variant-numeric: tabular-nums; opacity: 0.75; border-left: 1px solid currentColor; padding-left: 9px; }

  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; padding: 30px; margin: 8px 0 48px; background: var(--panel); border: 1px solid var(--panel-edge); border-radius: 14px; }
  .stat .n { font-family: var(--mono); font-size: clamp(24px, 4vw, 34px); font-weight: 700; color: var(--ink); font-variant-numeric: tabular-nums; line-height: 1; }
  .stat .l { font-family: var(--mono); font-size: 12.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--dim); margin-top: 9px; }

  section { padding: 30px 0; }
  h2 { font-size: 15px; font-family: var(--mono); letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); margin-bottom: 22px; font-weight: 700; }
  h3 { font-size: 21px; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.01em; }
  p.body { color: var(--muted); max-width: 68ch; margin-bottom: 16px; }

  .findings { display: grid; gap: 18px; }
  .finding { background: var(--panel); border: 1px solid var(--panel-edge); border-left: 3px solid var(--accent); border-radius: 10px; padding: 22px 24px; }
  .finding.warn { border-left-color: var(--warn); }
  .finding p { color: var(--muted); font-size: 15.5px; }
  .finding code { font-family: var(--mono); color: var(--ink); font-size: 0.92em; }

  pre { background: var(--code-bg); border: 1px solid var(--panel-edge); border-radius: 10px; padding: 18px 20px; overflow-x: auto; font-family: var(--mono); font-size: 14px; color: var(--ink); line-height: 1.7; }
  .comment { color: var(--dim); }

  footer { padding: 48px 0 64px; color: var(--dim); font-family: var(--mono); font-size: 13.5px; border-top: 1px solid var(--panel-edge); margin-top: 40px; }
  footer a { color: var(--muted); }

  /* post list */
  .postlist { display: grid; gap: 14px; }
  .postcard { display: block; background: var(--panel); border: 1px solid var(--panel-edge); border-radius: 10px; padding: 20px 22px; transition: border-color .15s, transform .15s; }
  .postcard:hover { text-decoration: none; border-color: var(--accent-dim); transform: translateY(-2px); }
  .postcard .meta { font-family: var(--mono); font-size: 12.5px; color: var(--dim); display: flex; gap: 10px; align-items: center; margin-bottom: 8px; }
  .postcard .ext { color: var(--accent); }
  .postcard h3 { color: var(--ink); margin-bottom: 6px; }
  .postcard p { color: var(--muted); font-size: 14.5px; }

  /* article body */
  article.post { max-width: 68ch; }
  article.post .meta { font-family: var(--mono); font-size: 13px; color: var(--dim); margin-bottom: 28px; }
  article.post h1 { font-size: clamp(28px, 5vw, 42px); margin-bottom: 16px; }
  article.post h2 { color: var(--ink); font-family: var(--sans); font-size: 24px; letter-spacing: -0.01em; text-transform: none; margin: 36px 0 12px; }
  article.post p { color: var(--ink); margin-bottom: 16px; }
  article.post ul, article.post ol { color: var(--ink); margin: 0 0 16px 1.4em; }
  article.post li { margin-bottom: 6px; }
  article.post blockquote { border-left: 3px solid var(--accent); padding: 4px 0 4px 18px; margin: 0 0 16px; color: var(--muted); font-style: italic; }
  article.post code { font-family: var(--mono); background: var(--code-bg); padding: 1px 6px; border-radius: 5px; font-size: 0.9em; }
  article.post a { color: var(--accent); }
  .backlink { font-family: var(--mono); font-size: 13px; color: var(--muted); display: inline-block; margin: 8px 0 28px; }

  @media (max-width: 680px) { .stats { grid-template-columns: repeat(2, 1fr); } }
</style>

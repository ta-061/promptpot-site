---
const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang={Astro.props.lang ?? 'en'}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content="https://promptpot.tatu-sec.dev/og-image.jpg" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ccircle cx='8' cy='8' r='6' fill='%233fb950'/%3E%3C/svg%3E" />
</head>
<body>
  <slot />
  <!-- Cloudflare Web Analytics -->
  <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "9385fd5fe6d940a0ae9a0e8c1503323c"}'></script>
</body>
</html>

<style is:global>
  :root {
    --ground: #0d1117;
    --ground-2: #0b0f14;
    --panel: #161b22;
    --panel-edge: #2a313c;
    --ink: #e6edf3;
    --muted: #8b98a5;
    --dim: #5c6773;
    --phosphor: #3fb950;
    --phosphor-dim: #2ea043;
    --amber: #d29922;
    --mono: ui-monospace, "SF Mono", "SFMono-Regular", Menlo, Consolas, monospace;
    --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    --maxw: 940px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background:
      radial-gradient(900px 480px at 85% -8%, rgba(63,185,80,0.08), transparent 62%),
      linear-gradient(165deg, var(--ground) 0%, var(--ground-2) 100%);
    background-attachment: fixed;
    min-height: 100vh;
    color: var(--ink);
    font-family: var(--sans);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--phosphor); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }

  .topbar { display: flex; justify-content: flex-end; align-items: center; gap: 8px; padding: 20px 0 0; font-family: var(--mono); font-size: 13px; }
  .topbar .lang { color: var(--dim); }
  .topbar .lang a, .topbar .lang span { padding: 4px 8px; border-radius: 6px; }
  .topbar .lang .active { background: var(--panel); color: var(--ink); border: 1px solid var(--panel-edge); }

  header { padding: 48px 0 52px; }
  .eyebrow {
    font-family: var(--mono); font-size: 14px; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--phosphor);
    display: inline-flex; align-items: center; gap: 10px; margin-bottom: 22px;
  }
  .eyebrow .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--phosphor); box-shadow: 0 0 9px 2px rgba(63,185,80,0.55); }
  h1 { font-size: clamp(34px, 6vw, 58px); line-height: 1.03; font-weight: 800; letter-spacing: -0.02em; text-wrap: balance; margin-bottom: 20px; }
  h1 .hl { color: var(--phosphor); }
  .lede { font-size: clamp(17px, 2.4vw, 21px); color: var(--muted); max-width: 62ch; margin-bottom: 34px; }
  .cta-row { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .btn {
    font-family: var(--mono); font-size: 15px; font-weight: 600;
    padding: 12px 20px; border-radius: 9px; border: 1px solid var(--panel-edge);
    color: var(--ink); background: var(--panel); transition: border-color .15s, transform .15s;
    display: inline-flex; align-items: center; gap: 9px;
  }
  .btn:hover { text-decoration: none; border-color: var(--phosphor-dim); transform: translateY(-1px); }
  .btn.primary { background: var(--phosphor); color: #08240f; border-color: var(--phosphor); }
  .btn.primary:hover { background: #4fc662; }
  .btn .metric { font-variant-numeric: tabular-nums; color: var(--dim); border-left: 1px solid var(--panel-edge); padding-left: 9px; }
  .btn.primary .metric { color: #0b3d1b; border-color: rgba(8,36,15,0.25); }

  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; padding: 30px; margin: 8px 0 48px; background: var(--panel); border: 1px solid var(--panel-edge); border-radius: 14px; }
  .stat .n { font-family: var(--mono); font-size: clamp(24px, 4vw, 34px); font-weight: 700; color: var(--ink); font-variant-numeric: tabular-nums; line-height: 1; }
  .stat .l { font-family: var(--mono); font-size: 12.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--dim); margin-top: 9px; }

  section { padding: 30px 0; }
  h2 { font-size: 15px; font-family: var(--mono); letter-spacing: 0.16em; text-transform: uppercase; color: var(--phosphor); margin-bottom: 22px; font-weight: 700; }
  h3 { font-size: 21px; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.01em; }
  p.body { color: var(--muted); max-width: 68ch; margin-bottom: 16px; }

  .findings { display: grid; gap: 18px; }
  .finding { background: var(--panel); border: 1px solid var(--panel-edge); border-left: 3px solid var(--phosphor); border-radius: 10px; padding: 22px 24px; }
  .finding.warn { border-left-color: var(--amber); }
  .finding p { color: var(--muted); font-size: 15.5px; }
  .finding code { font-family: var(--mono); color: var(--ink); font-size: 0.92em; }

  pre { background: #10151c; border: 1px solid var(--panel-edge); border-radius: 10px; padding: 18px 20px; overflow-x: auto; font-family: var(--mono); font-size: 14px; color: var(--ink); line-height: 1.7; }
  .comment { color: var(--dim); }

  footer { padding: 48px 0 64px; color: var(--dim); font-family: var(--mono); font-size: 13.5px; border-top: 1px solid var(--panel-edge); margin-top: 40px; }
  footer a { color: var(--muted); }

  @media (max-width: 680px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
